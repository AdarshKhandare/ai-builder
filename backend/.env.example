# ─── OpenCode Go API ─────────────────────────────────────────────────
# Get your key at https://opencode.ai/auth
# The same key works for both the OpenAI-compatible and Anthropic
# /messages endpoints on the Go gateway.
OPENCODE_API_KEY=your-key-here
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# ─── Planner model (optional override) ──────────────────────────────
# Default: opencode-go/deepseek-v4-flash (cheapest reasoning model).
# Uncomment and set this to switch to a different planner model — useful
# as an operational fallback if the default is degraded upstream.
# Examples:
#   PLANNER_MODEL=opencode-go/kimi-k2.6          # $0.95 / $4.0 per 1M
#   PLANNER_MODEL=opencode-go/mimo-v2.5-pro      # $1.74 / $3.48 per 1M
#   PLANNER_MODEL=opencode-go/qwen3.7-plus       # $0.40 / $1.6 per 1M
# PLANNER_MODEL=opencode-go/kimi-k2.6

# ─── Database ────────────────────────────────────────────────────────
# Async SQLite via aiosqlite. The file lives in backend/data/forge.db
# (created at first run; the data/ directory is gitignored).
DATABASE_URL=sqlite+aiosqlite:///./data/forge.db

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated origins OR a JSON list. pydantic-settings will parse
# the JSON list form. Add production origins when deploying.
ALLOWED_ORIGINS=["http://localhost:5173"]
