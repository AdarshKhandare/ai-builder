# ─── OpenCode Go API ─────────────────────────────────────────────────
# Get your key at https://opencode.ai/auth
# The same key works for both the OpenAI-compatible and Anthropic
# /messages endpoints on the Go gateway.
OPENCODE_API_KEY=your-key-here
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# ─── Planner model (optional override) ──────────────────────────────
# Default: opencode-go/deepseek-v4-flash (cheapest reasoning model).
# Uncomment and set this to switch to a different planner model — useful
# as an operational fallback if the default is degraded upstream.
# Examples:
#   PLANNER_MODEL=opencode-go/kimi-k2.6          # $0.95 / $4.0 per 1M
#   PLANNER_MODEL=opencode-go/mimo-v2.5          # $0.14 / $0.28 per 1M
#   PLANNER_MODEL=opencode-go/qwen3.7-plus       # $0.40 / $1.6 per 1M
# PLANNER_MODEL=opencode-go/kimi-k2.6

# ─── Database ────────────────────────────────────────────────────────
# Async SQLite via aiosqlite. The file lives in backend/data/forge.db
# (created at first run; the data/ directory is gitignored).
DATABASE_URL=sqlite+aiosqlite:///./data/forge.db

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated origins OR a JSON list. pydantic-settings will parse
# the JSON list form. Add production origins when deploying.
ALLOWED_ORIGINS=["http://localhost:5173"]

# ─── Environment ─────────────────────────────────────────────────────
# "development" (default) or "production". Drives HSTS, cookie
# Secure flag, and other prod-only middleware. Setting this to
# "production" without HTTPS in front is a configuration error.
ENVIRONMENT=development

# ─── GitHub OAuth (Task 2) ───────────────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/applications/new
# Set "Homepage URL" to FRONTEND_URL and "Authorization callback URL" to
#   <FRONTEND_URL>/api/auth/callback
# (GitHub accepts the backend callback URL because the route redirects
# to FRONTEND_URL after exchanging the code; the callback URL on
# GitHub's side MUST point at the backend, i.e. include /api/auth/callback
# in the backend's public URL — e.g. https://api.adarshweb.in/api/auth/callback.)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── JWT (Task 2) ────────────────────────────────────────────────────
# A long random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# If empty in production, the auth module will refuse to issue tokens.
JWT_SECRET=xBrd3LYaGRCzPBjGVaov1RlVFzGejClsMuZcqGXGR96pd8ko4Q6l0ptLOT0DPsbdP6ZriuxtzJ_YXY6_36xQ
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ─── Frontend URL (Task 2) ───────────────────────────────────────────
# Where to redirect after a successful GitHub OAuth login.
# Default points at the local Vite dev server.
FRONTEND_URL=http://localhost:5173

# Public origin of the backend — used to build the GitHub OAuth
# callback URL registered on the GitHub OAuth app. Defaults to
# localhost:8000 for dev. In production set this to the API's
# public origin (e.g. https://api.adarshweb.in).
BACKEND_PUBLIC_URL=http://localhost:8000
